---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import TechBadge from '../components/TechBadge.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { Image } from 'astro:assets';

import { projects } from '../data/projects.js';

const pageTitle = "Inicio";

const featuredProjects = projects.filter(p => p.featured).slice(0, 3);


const servicesSet = [
  {
     id: 1,
     title: "Desarrollo Web a Medida",
     description: "Aplicaciones y sitios web construidos desde cero en PHP o JavaScript puro. Calidad de código garantizada.",
     icon: "code" as const
  },
  {
     id: 2,
     title: "Sitios WordPress",
     description: "Sitios institucionales y tiendas con Elementor o Divi, rápidos, seguros y fáciles de editar por vos.",
     icon: "wordpress" as const
  },
  {
     id: 3,
     title: "Landing Pages",
     description: "Páginas de aterrizaje optimizadas para convertir visitas en clientes reales. Ideales para tus campañas.",
     icon: "rocket" as const
  },
  {
     id: 4,
     title: "Mantenimiento",
     description: "Actualizaciones, backups, seguridad y soporte continuo para que tu sitio nunca te deje a gamba.",
     icon: "wrench" as const
  }
];
---

<BaseLayout pageTitle={pageTitle}>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Facundo Rodriguez",
      "jobTitle": "Desarrollador Web Freelance",
      "url": "https://facundoweb.com",
      "sameAs": [
        "https://github.com/facundorodriguez19",
        "https://www.linkedin.com/in/facundo-rodriguez-16169014b/"
      ]
    }
  </script>
  <!-- SECTION 1: HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-16 md:pt-12 overflow-hidden bg-transparent">
    <!-- Background Glow Texture -->
    <div class="absolute top-0 right-0 w-[500px] md:w-[700px] h-[500px] md:h-[700px] bg-accent/5 rounded-full blur-[100px] md:blur-[160px] -mr-40 -mt-40 pointer-events-none"></div>

    <div class="max-w-[1200px] w-full mx-auto px-6 grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-12 items-center relative z-10">
      <!-- Left Column -->
      <div class="flex flex-col gap-8 animate-container">
        <!-- Availability Badge -->
        <div class="flex items-center gap-3 self-start px-3.5 py-1.5 border border-border-hover rounded-badge bg-card/50 backdrop-blur-sm animate-item">
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse shadow-[0_0_8px_var(--accent-color)]"></span>
          <span class="text-[12px] font-body text-text-secondary uppercase tracking-[0.1em]">Disponible para proyectos</span>
        </div>

        <!-- Heading -->
        <h1 class="flex flex-col font-display leading-[0.9] animate-item">
          <span class="text-[42px] md:text-[72px] text-text-primary tracking-tight">Transformá tu Presencia</span>
          <span class="text-[52px] md:text-[96px] text-accent tracking-normal drop-shadow-[0_0_20px_rgba(0,212,170,0.15)]">En Resultados Reales.</span>
        </h1>

        <!-- Subheading -->
        <p class="text-text-secondary text-[18px] md:text-[22px] max-w-[520px] leading-[1.6] font-body animate-item">
          Desarrollo sitios web que no solo se ven increíbles, sino que <span class="text-text-primary font-bold">venden y posicionan</span>. Soluciones a medida en PHP y JavaScript para emprendedores ambiciosos.
        </p>

        <!-- Tech Stack Badges -->
        <div class="flex flex-wrap gap-2 animate-item">
          <TechBadge text="PHP" />
          <TechBadge text="JavaScript" />
          <TechBadge text="WordPress" />
          <TechBadge text="Elementor" />
          <TechBadge text="Divi" />
          <TechBadge text="HTML/CSS" />
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 pt-4 animate-item">
          <Button text="Clique aqui para existir" href="/contacto" variant="primary" class="cta-button" />
          <Button text="Ver portafolio" href="/proyectos" variant="secondary" />
        </div>
      </div>

      <!-- Right Column: Visual Component -->
      <div class="hidden lg:flex justify-center items-center animate-item-delayed relative group">
        <!-- Floating Elements Decor -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent/10 rounded-full blur-3xl animate-pulse delay-700"></div>
        <div class="absolute bottom-0 left-0 w-32 h-32 bg-accent/5 rounded-full blur-3xl animate-pulse"></div>

        <div class="relative w-[480px] aspect-[4/3] rounded-card overflow-hidden border border-white/10 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.5)] bg-[#0A0A0A]/50 backdrop-blur-md transition-all duration-700 hover:border-accent/40 hover:shadow-accent/5 group">
          <Image 
            src={import('../assets/images/ui/profile-visual.png')} 
            alt="Facundo Rodriguez Profile Visual" 
            width={480}
            height={360}
            format="webp"
            quality={90}
            class="w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000"
            loading="eager"
          />

          
          <!-- Glass Overlay for data -->
          <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
          
          <!-- Tech Floating Badges inside the visual container -->
          <div class="absolute top-6 right-6 flex flex-col gap-3">
            <div class="bg-black/60 backdrop-blur-xl border border-white/10 px-4 py-2 rounded-full text-[10px] font-bold text-accent uppercase tracking-widest shadow-xl animate-float">PHP 8.2</div>
            <div class="bg-black/60 backdrop-blur-xl border border-white/10 px-4 py-2 rounded-full text-[10px] font-bold text-accent uppercase tracking-widest shadow-xl animate-float delay-300">Astro 4</div>
            <div class="bg-black/60 backdrop-blur-xl border border-white/10 px-4 py-2 rounded-full text-[10px] font-bold text-accent uppercase tracking-widest shadow-xl animate-float delay-700">JS ESNext</div>
          </div>

          <!-- Bottom Label -->
          <div class="absolute bottom-6 left-6 right-6 p-4 bg-white/5 backdrop-blur-2xl border border-white/10 rounded-xl flex items-center justify-between">
            <div class="flex flex-col">
              <span class="text-text-muted text-[10px] uppercase font-bold tracking-widest">Status Actual</span>
              <span class="text-white font-body font-bold text-sm tracking-wide">8 Proyectos Activos</span>
            </div>
            <div class="h-8 w-[1px] bg-white/10"></div>
            <div class="flex flex-col items-end">
              <span class="text-text-muted text-[10px] uppercase font-bold tracking-widest">Localización</span>
              <span class="text-white font-body font-bold text-sm tracking-wide">Brasil</span>
            </div>
          </div>
        </div>

        <!-- Extra Floating Decor -->
        <div class="absolute -top-12 -right-12 w-24 h-24 border-l border-t border-accent/20 rounded-tl-3xl animate-pulse"></div>
        <div class="absolute -bottom-12 -left-12 w-24 h-24 border-r border-b border-accent/20 rounded-br-3xl animate-pulse delay-1000"></div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: ESTADÍSTICAS -->
  <section class="bg-transparent border-y border-border py-12 px-6">
    <div class="max-w-[1200px] mx-auto grid grid-cols-2 lg:grid-cols-4 gap-x-4 gap-y-12 divide-x-0 lg:divide-x lg:divide-border/50">
      <div class="flex flex-col items-center text-center px-4 reveal" data-delay="0">
        <span class="font-display text-[40px] md:text-[56px] text-accent leading-none stat-number" data-target="10">0</span>

        <span class="font-body text-[11px] md:text-[14px] text-text-secondary uppercase tracking-[0.1em] mt-2">Proyectos Completados</span>
      </div>
      <div class="flex flex-col items-center text-center px-4 reveal" data-delay="100">
        <span class="font-display text-[40px] md:text-[56px] text-accent leading-none stat-number" data-target="6">0</span>
        <span class="font-body text-[11px] md:text-[14px] text-text-secondary uppercase tracking-[0.1em] mt-2">Clientes Reales</span>
      </div>
      <div class="flex flex-col items-center text-center px-4 reveal" data-delay="200">
        <span class="font-display text-[40px] md:text-[56px] text-accent leading-none stat-number" data-target="3">0</span>
        <span class="font-body text-[11px] md:text-[14px] text-text-secondary uppercase tracking-[0.1em] mt-2">Tecnologías Principales</span>
      </div>
      <div class="flex flex-col items-center text-center px-4 reveal" data-delay="300">
        <div class="flex items-baseline">
          <span class="font-display text-[40px] md:text-[56px] text-accent leading-none stat-number" data-target="100">0</span>
          <span class="font-display text-xl md:text-3xl text-accent">%</span>
        </div>
        <span class="font-body text-[11px] md:text-[14px] text-text-secondary uppercase tracking-[0.1em] mt-2">Compromiso con el Cliente</span>
      </div>
    </div>
  </section>

  <!-- CTA INTERMEDIO -->
  <div class="flex justify-center py-12 reveal">
    <Button text="Clique aqui para existir" href="/contacto" variant="primary" class="cta-button" />
  </div>


  <!-- SECTION 3: PROYECTOS DESTACADOS -->
  <section class="py-24 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col mb-16 reveal">
        <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4 border-l-2 border-accent pl-4">/ PROYECTOS</span>
        <h2 class="mb-4">Trabajo Real, Resultados Reales</h2>
        <p class="text-text-secondary text-lg max-w-[600px] font-body leading-relaxed">
          No demos. No templates. Proyectos construidos para clientes y para mí.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {featuredProjects.map((project, index) => (
          <div class="reveal" data-delay={index * 100}>
            <ProjectCard {...project} />
          </div>
        ))}
      </div>

      <div class="flex justify-center reveal" data-delay="400">
        <Button text="Ver todos los proyectos →" href="/proyectos" variant="outline" />
      </div>
    </div>
  </section>

  <!-- SECTION 4: SERVICIOS -->
  <section class="py-24 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col mb-16 items-center text-center reveal">
        <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4">/ SERVICIOS</span>
        <h2 class="mb-4">¿En qué puedo ayudarte?</h2>
        <p class="text-text-secondary text-lg max-w-[600px] font-body leading-relaxed">
          Desarrollo soluciones web adaptadas a cada necesidad y presupuesto.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {servicesSet.map((service, index) => (
          <div class="reveal" data-delay={index * 100}>
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 5: SOBRE MÍ (mini) -->
  <section class="py-24 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-[1.2fr_1fr] gap-16 items-center">
      <div class="flex flex-col gap-8 reveal" data-delay="0">
        <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-2 border-l-2 border-accent pl-4">/ SOBRE MÍ</span>
        <h2 class="leading-tight">Un desarrollador que entrega lo que promete</h2>
        <div class="flex flex-col gap-6 font-body text-text-secondary leading-relaxed text-lg">
          <p>Soy desarrollador web freelance con experiencia en <span class="text-text-primary">PHP, JavaScript y WordPress</span>. Trabajo con clientes reales en proyectos que necesitan resultados concretos.</p>
          <p>Cada proyecto que arranco lo termino. Sin excusas, sin proyectos abandonados. Tu sitio sale cuando decimos que sale.</p>
          <p>Además de trabajar para clientes, desarrollo mis propios proyectos y escribo sobre lo que aprendo.</p>
        </div>
        <div class="pt-4">
          <Button text="Contactame" href="/contacto" variant="primary" />
        </div>
      </div>

      <div class="flex flex-col gap-0 border border-border bg-transparent rounded-card p-4 reveal" data-delay="200">
        {[
          "Entrego en tiempo y forma",
          "Código limpio y documentado",
          "Comunicación clara y constante",
          "Precios transparentes, sin sorpresas",
          "Soporte post-lanzamiento"
        ].map((valor) => (
          <div class="flex items-center gap-4 py-5 border-b border-border/50 last:border-0 px-4 group hover:bg-white/5 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span class="font-body text-text-primary font-medium">{valor}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6: CTA FINAL -->
  <section class="py-32 px-6 relative overflow-hidden bg-transparent">
    <!-- Glow effect -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-[600px] mx-auto text-center relative z-10 flex flex-col gap-8 reveal">
      <h2 class="text-5xl md:text-[56px] font-display uppercase tracking-wider leading-none">¿Tenés un proyecto en mente?</h2>
      <p class="text-text-secondary text-lg font-body max-w-[500px] mx-auto">
        Escribime y hablemos. La primera consulta es gratis.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 pt-4">
        <Button text="Empezar proyecto →" href="/contacto" variant="primary" />
        <Button text="Ver mis proyectos" href="/proyectos" variant="secondary" />
      </div>
    </div>
  </section>

  <style>
    /* Hero animations */
    .animate-container { perspective: 1000px; }
    .animate-item {
      opacity: 0;
      transform: translateY(24px);
      animation: fadeInUp 0.6s ease forwards;
    }
    .animate-item:nth-child(1) { animation-delay: 0.1s; }
    .animate-item:nth-child(2) { animation-delay: 0.2s; }
    .animate-item:nth-child(3) { animation-delay: 0.3s; }
    .animate-item:nth-child(4) { animation-delay: 0.4s; }
    .animate-item:nth-child(5) { animation-delay: 0.5s; }

    .cta-button {
      min-height: 44px;
      padding: 12px 20px;
    }

    .animate-item-delayed {
      opacity: 0;
      transform: scale(0.95) rotate(-2deg);
      animation: zoomFade 1s ease 0.6s forwards;
    }

    @keyframes fadeInUp {
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes zoomFade {
      to { opacity: 1; transform: scale(1); }
    }

    /* Floating animation for tech badges */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    .animate-float {
      animation: float 4s ease-in-out infinite;
    }
    .delay-300 { animation-delay: 0.3s; }
    .delay-700 { animation-delay: 0.7s; }
    .delay-1000 { animation-delay: 1s; }

    /* Scroll animations */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: all 0.6s ease;
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    // Intersection Observer for scroll animations
    const revealElements = document.querySelectorAll('.reveal');
    const statNumbers = document.querySelectorAll('.stat-number');

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = parseInt((entry.target as HTMLElement).getAttribute('data-delay') || '0');
          setTimeout(() => {
            entry.target.classList.add('active');
            
            // If it's a stat number, start counting
            const statNum = entry.target.querySelector('.stat-number');
            if (statNum) startCounter(statNum as HTMLElement);
            else if (entry.target.classList.contains('stat-number')) startCounter(entry.target as HTMLElement);
          }, delay);
        }
      });
    }, { threshold: 0.1 });

    const startCounter = (el: HTMLElement) => {
      if (el.getAttribute('data-started')) return;
      el.setAttribute('data-started', 'true');
      
      const target = parseInt(el.getAttribute('data-target') || '0');
      const duration = 2000;
      const startTime = performance.now();
      
      const update = (currentTime: number) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const current = Math.floor(progress * target);
        el.textContent = current.toString();
        
        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = target.toString();
        }
      };
      
      requestAnimationFrame(update);
    };

    revealElements.forEach(el => revealObserver.observe(el));
  </script>
</BaseLayout>
