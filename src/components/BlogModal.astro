---
// src/components/BlogModal.astro
---

<div id="blog-modal" class="fixed inset-0 z-[600] hidden items-center justify-center p-4 md:p-8">
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  
  <!-- Modal Content -->
  <div id="modal-container" class="relative w-full max-w-4xl max-h-[90vh] glass-card overflow-hidden flex flex-col scale-95 opacity-0 transition-all duration-300 translate-y-4">
    <!-- Close Button -->
    <button id="close-modal" class="absolute top-6 right-6 z-10 p-2 rounded-full bg-black/20 hover:bg-white/10 transition-colors text-white/70 hover:text-white border border-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>

    <!-- Scrollable content -->
    <div class="overflow-y-auto p-8 md:p-12 custom-scrollbar">
      <header class="mb-10">
        <div id="modal-category-container" class="mb-4">
           <span id="modal-category" class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-badge border"></span>
        </div>
        <h2 id="modal-title" class="text-3xl md:text-5xl font-bold font-body leading-tight mb-6"></h2>
        <div class="flex items-center gap-4 text-text-muted text-sm font-body">
          <span id="modal-date"></span>
          <span>·</span>
          <span id="modal-read-time"></span>
        </div>
      </header>

      <div id="modal-content" class="max-w-none font-body leading-relaxed text-text-secondary">
        <!-- Content will be injected here -->
      </div>
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Style for injected HTML */
  #modal-content :global(h3) {
    font-size: 1.75rem;
    font-weight: 700;
    color: white;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-body);
  }

  #modal-content :global(p) {
    margin-bottom: 1.5rem;
    color: #a1a1aa; /* text-zinc-400 equivalent */
    font-size: 1.125rem;
    line-height: 1.8;
  }

  #modal-content :global(ul), #modal-content :global(ol) {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
    color: #a1a1aa;
    font-size: 1.125rem;
  }

  #modal-content :global(ul) {
    list-style-type: disc;
  }
  
  #modal-content :global(ul li::marker) {
    color: var(--accent-color, #00d4aa);
  }

  #modal-content :global(ol) {
    list-style-type: decimal;
  }

  #modal-content :global(li) {
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
  }

  #modal-content :global(strong) {
    color: white;
    font-weight: 600;
  }

  #modal-content :global(code) {
    background: rgba(255, 255, 255, 0.08);
    color: #00d4aa;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: monospace;
  }
</style>

<script>
  import { blogPosts } from '../data/blog-posts.js';

  const modal = document.getElementById('blog-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const container = document.getElementById('modal-container');
  const closeBtn = document.getElementById('close-modal');
  
  const titleEl = document.getElementById('modal-title');
  const categoryEl = document.getElementById('modal-category');
  const dateEl = document.getElementById('modal-date');
  const readTimeEl = document.getElementById('modal-read-time');
  const contentEl = document.getElementById('modal-content');

  function openModal(slug) {
    const post = blogPosts.find(p => p.slug === slug);
    if (!post) return;

    // Set content
    titleEl.textContent = post.title;
    categoryEl.textContent = post.category;
    categoryEl.style.backgroundColor = `${post.categoryColor}22`;
    categoryEl.style.borderColor = `${post.categoryColor}44`;
    categoryEl.style.color = post.categoryColor;
    
    dateEl.textContent = new Date(post.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
    readTimeEl.textContent = `${post.readTime} de lectura`;
    contentEl.innerHTML = post.content;

    // Show modal
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Animate in
    setTimeout(() => {
      backdrop.classList.add('opacity-100');
      container.classList.add('opacity-100', 'scale-100', 'translate-y-0');
      container.classList.remove('scale-95', 'translate-y-4');
    }, 10);

    // Prevent scroll
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    // Animate out
    backdrop.classList.remove('opacity-100');
    container.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
    container.classList.add('scale-95', 'translate-y-4');

    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }, 300);
  }

  // Event Listeners
  document.addEventListener('click', (e) => {
    const target = e.target;
    const blogTrigger = target.closest('[data-blog-slug]');
    
    if (blogTrigger) {
      e.preventDefault();
      const slug = blogTrigger.getAttribute('data-blog-slug');
      openModal(slug);
    }
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>
