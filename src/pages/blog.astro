---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import BlogModal from '../components/BlogModal.astro';
import Button from '../components/Button.astro';
import { blogPosts } from '../data/blog-posts.js';

const pageTitle = "Blog";
const featuredPost = blogPosts[0];
const remainingPosts = blogPosts.slice(1);
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Header -->
  <header class="pt-[120px] pb-12 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto flex flex-col items-center text-center">
      <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4 border-l-2 border-accent pl-4">/ BLOG</span>
      <h1 class="mb-6">Bitácora de Desarrollador</h1>
      <p class="text-text-secondary text-lg max-w-[600px] font-body leading-relaxed">
        Escribo sobre lo que construyo y lo que aprendo. Sin relleno, directo al código y a la experiencia real.
      </p>
    </div>
  </header>

  <section class="max-w-[1200px] mx-auto px-6 pb-24">
    <!-- Featured Article -->
    <div class="mb-16">
      <a href={`/blog/${featuredPost.slug}`} data-blog-slug={featuredPost.slug} class="glass-card flex flex-col lg:flex-row group overflow-hidden border transition-all duration-300 hover:border-border-hover relative">
        <span class="absolute top-6 left-6 z-10 bg-accent text-[#080808] text-[10px] font-bold px-2 py-1 rounded-badge uppercase tracking-widest">Artículo destacado</span>
        
        <!-- Left: Content area -->
        <div class="lg:w-[55%] p-8 md:p-12 flex flex-col gap-6">
          <span 
            class="self-start text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-badge border"
            style={{ backgroundColor: `${featuredPost.categoryColor}22`, borderColor: `${featuredPost.categoryColor}44`, color: featuredPost.categoryColor }}
          >
            {featuredPost.category}
          </span>
          <h2 class="text-3xl md:text-[36px] font-bold font-body leading-tight group-hover:text-accent transition-colors">
            {featuredPost.title}
          </h2>
          <p class="text-text-secondary text-lg leading-relaxed font-body">
            {featuredPost.excerpt}
          </p>
          <div class="flex items-center gap-4 text-text-muted text-sm font-body">
            <span>{new Date(featuredPost.date).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <span>·</span>
            <span>{featuredPost.readTime} de lectura</span>
          </div>
          <div class="pt-4">
            <span class="text-accent text-[14px] font-bold uppercase tracking-widest flex items-center gap-2 group-hover:gap-3 transition-all font-body">
              Leer artículo <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </div>
        </div>

        <!-- Right: Image/Gradient area -->
        <div 
          class="lg:w-[45%] h-[300px] lg:h-auto relative"
          style={{ background: featuredPost.coverGradient }}
        >
          <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
        </div>
      </a>
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      {remainingPosts.map((post) => (
        <BlogCard {...post} />
      ))}
    </div>

    
  </section>

  <BlogModal />
</BaseLayout>
