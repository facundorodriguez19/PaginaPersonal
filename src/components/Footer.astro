---
import { Image } from 'astro:assets';
import logo from '../assets/images/ui/logo.png';
const currentYear = new Date().getFullYear();
---

<footer class="bg-transparent border-t border-border pt-16 pb-8 h-auto">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16 px-6">
    <!-- Brand Info -->
    <div class="flex flex-col gap-6">
      <a href="/" class="flex items-center group transition-transform origin-left">
        <Image src={logo} alt="Facundo Rodriguez" width={200} height={100} format="webp" loading="lazy" class="h-auto w-[150px] object-contain brightness-110 mix-blend-screen" />
      </a>

      <p class="text-text-secondary text-sm leading-relaxed font-body">
        Desarrollador Web Freelance. Transformo ideas en productos digitales reales.
      </p>
    </div>

    <!-- Columna 2: Navegación -->
    <div class="flex flex-col gap-6">
      <span class="text-accent font-display text-xs uppercase tracking-widest px-2 py-1 border border-accent/20 bg-accent/5 self-start rounded-badge">
        Páginas
      </span>
      <ul class="flex flex-col gap-3">
        <li><a href="/" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium uppercase tracking-[0.05em] font-body">Inicio</a></li>
        <li><a href="/proyectos" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium uppercase tracking-[0.05em] font-body">Proyectos</a></li>
        <li><a href="/servicios" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium uppercase tracking-[0.05em] font-body">Servicios</a></li>
        <li><a href="/blog" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium uppercase tracking-[0.05em] font-body">Blog</a></li>
        <li><a href="/contacto" class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium uppercase tracking-[0.05em] font-body">Contacto</a></li>
      </ul>
    </div>

    <!-- Columna 3: Contacto -->
    <div class="flex flex-col gap-6">
      <span class="text-accent font-display text-xs uppercase tracking-widest px-2 py-1 border border-accent/20 bg-accent/5 self-start rounded-badge">
        Contacto
      </span>
      <a href="mailto:Facundo.rodriguez.pro@gmail.com" class="text-text-primary hover:text-accent transition-colors font-body font-bold text-lg">
        Facundo.rodriguez.pro@gmail.com
      </a>
      
      <!-- Socials -->
      <div class="flex gap-4 items-center">
        <a href="https://github.com/facundorodriguez19" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors p-2 border border-border hover:border-accent/30 rounded-badge" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </a>
        <a href="https://www.linkedin.com/in/facundo-rodriguez-16169014b/" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors p-2 border border-border hover:border-accent/30 rounded-badge" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-border pt-8 px-6 max-w-[1200px] mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="text-text-muted text-[13px] font-body">
      &copy; {currentYear} Facundo Rodriguez. Todos los derechos reservados.
    </p>
  </div>
</footer>
