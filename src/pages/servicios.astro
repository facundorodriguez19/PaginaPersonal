---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { services } from '../data/services.js';

const pageTitle = "Servicios";

const faqs = [
  {
    q: "¿Trabajás con clientes de cualquier país?",
    a: "Sí, trabajo de forma 100% remota con clientes de Argentina, Uruguay, y cualquier otro país hispanohablante."
  },
  {
    q: "¿Cuánto tarda un sitio WordPress?",
    a: "Dependiendo de la complejidad, entre 1 y 3 semanas. Landing pages en 3-7 días."
  },
  {
    q: "¿Qué necesito para empezar?",
    a: "Solo contarme qué necesitás. Si no tenés dominio o hosting, te ayudo a elegir los mejores para tu presupuesto."
  },
  {
    q: "¿Doy facturas?",
    a: "Sí, emito recibo o factura según corresponda."
  },
  {
    q: "¿Qué pasa si no me gusta el resultado?",
    a: "Trabajo con revisiones incluidas hasta que el resultado sea el acordado. Tu satisfacción es parte del servicio."
  }
];
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Hero Section -->
  <header class="pt-[120px] pb-12 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto flex flex-col items-center text-center">
      <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4 border-l-2 border-accent pl-4">/ SERVICIOS</span>
      <h1 class="mb-6">Cuidando cada detalle</h1>
      <p class="text-text-secondary text-lg max-w-[600px] font-body leading-relaxed">
        Trabajo en lo que sé hacer bien. Sin inventar servicios que no domino. Mi enfoque es la calidad sobre la cantidad.
      </p>
    </div>
  </header>

  <!-- Services Layout -->
  <section class="flex flex-col">
    {services.map((service, index) => (
      <div class={`py-20 px-6 bg-transparent`}>
        <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <!-- Text Content -->
          <div class={`flex flex-col gap-6 ${index % 2 !== 0 ? 'lg:order-2' : ''}`}>
            <!-- Icon 64px -->
            <div class="w-16 h-16 bg-accent/10 border border-accent/20 rounded-xl flex items-center justify-center text-accent mb-2">
              {service.icon === 'code' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>}
              {service.icon === 'wordpress' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"></path><path d="M16 12l-2-6-2 6-2-6-2 6s0 0 0 0h2.5l2 4 2-4h2.5s0 0 0 0z"></path></svg>}
              {service.icon === 'rocket' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.71-2.13.09-2.91a2.18 2.18 0 0 0-3.09-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path></svg>}
              {service.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>}
            </div>

            <span class="text-accent/80 font-body text-xs uppercase tracking-widest font-bold">{service.subtitle}</span>
            <h2 class="text-4xl md:text-[48px] font-display uppercase leading-tight">{service.title}</h2>
            <p class="text-text-secondary text-lg leading-relaxed font-body">{service.description}</p>
            
            <div class="flex flex-wrap items-center gap-6 mt-4">
              <div class="flex flex-col">
                <span class="text-white font-display text-2xl leading-none">{service.priceRange}</span>
                <span class="text-text-muted text-[11px] uppercase tracking-wider">Inversión estimada</span>
              </div>
              <div class="h-10 w-px bg-border hidden sm:block"></div>
              <div class="flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <span class="text-text-secondary font-body text-sm italic">{service.deliveryTime}</span>
              </div>
            </div>

            <div class="pt-4">
              <Button text="Solicitar este servicio →" href={`/contacto?servicio=${service.title}`} variant="primary" />
            </div>
          </div>

          <!-- Features Card -->
          <div class={`bg-card border border-border rounded-card p-8 md:p-10 transition-all hover:border-accent/40 ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
            <h3 class="text-lg font-bold mb-6 font-body text-text-primary uppercase tracking-wider border-b border-border pb-4">¿Qué incluye?</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-1 gap-4 mb-10">
              {service.features.map((feature) => (
                <li class="flex items-start gap-3 group">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 group-hover:scale-110 transition-transform"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  <span class="text-text-secondary font-body text-[15px]">{feature}</span>
                </li>
              ))}
            </ul>
            <div class="pt-6 border-t border-border/50">
              <p class="text-text-muted text-[13px] font-body italic flex items-center gap-2">
                <strong class="text-accent not-italic">Ideal para:</strong> {service.idealFor}
              </p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- PROCESS SECTION -->
  <section class="py-24 px-6 bg-transparent">
    <div class="max-w-[1200px] mx-auto text-center mb-20">
      <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4">/ MI MÉTODO</span>
      <h2 class="mb-6">¿Cómo trabajo?</h2>
      <p class="text-text-secondary text-lg max-w-[600px] mx-auto font-body">Un proceso simple y claro, sin sorpresas ni idas y vueltas innecesarias.</p>
    </div>

    <div class="max-w-[1200px] mx-auto relative px-10">
      <!-- Horizontal line (desktop) -->
      <div class="absolute top-1/2 left-0 w-full h-0.5 bg-border -translate-y-1/2 hidden lg:block"></div>
      
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-12 relative z-10">
        {[
          { step: "1", title: "Conversamos", desc: "Me contás qué necesitás. Te doy una propuesta en 24hs." },
          { step: "2", title: "Planificamos", desc: "Definimos alcance, tiempos y precio. Firmamos el acuerdo." },
          { step: "3", title: "Construimos", desc: "Desarrollo tu proyecto con actualizaciones frecuentes." },
          { step: "4", title: "Lanzamos", desc: "Revisión final, ajustes, y tu proyecto sale al aire." }
        ].map((item, idx) => (
          <div class="flex flex-col items-center lg:items-start text-center lg:text-left group">
            <div 
              class={`w-12 h-12 rounded-full border-2 border-border mb-6 flex items-center justify-center font-display text-xl transition-all duration-500
                ${idx === 0 ? 'bg-accent border-accent text-primary' : 'bg-transparent text-text-muted group-hover:border-accent group-hover:text-accent'}`}
            >
              {item.step}
            </div>
            <h3 class="text-xl font-bold mb-3 font-body text-text-primary uppercase tracking-wider">{item.title}</h3>
            <p class="text-text-secondary text-[15px] max-w-[280px] font-body">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="py-24 px-6 bg-transparent">
    <div class="max-w-[800px] mx-auto">
      <div class="text-center mb-16">
        <span class="text-accent font-body text-xs uppercase tracking-[0.2rem] mb-4">/ PREGUNTAS</span>
        <h2 class="mb-6">Dudas Frecuentes</h2>
      </div>

      <div class="flex flex-col gap-0">
        {faqs.map((faq) => (
          <details class="group border-b border-border py-4">
            <summary class="flex justify-between items-center cursor-pointer list-none py-4 text-[17px] font-bold font-body text-text-primary hover:text-accent transition-colors">
              {faq.q}
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                width="20" height="20" 
                viewBox="0 0 24 24" fill="none" 
                stroke="currentColor" stroke-width="2" 
                stroke-linecap="round" stroke-linejoin="round"
                class="transition-transform duration-300 group-open:rotate-90 text-text-muted"
              >
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </summary>
            <div class="pb-6 pr-10">
              <p class="text-text-secondary font-body text-[15px] leading-relaxed">
                {faq.a}
              </p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA Callout -->
  

  <style>
    /* Details arrow fix for high browsers */
    details > summary::-webkit-details-marker {
      display: none;
    }
  </style>
</BaseLayout>
