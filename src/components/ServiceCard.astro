---
interface Props {
  id: number;
  title: string;
  description: string;
  icon: 'code' | 'wordpress' | 'rocket' | 'wrench';
}

const { id, title, description, icon } = Astro.props;
---

<div class="glass-card p-10 flex flex-col group relative overflow-hidden h-full rounded-card border transition-all duration-300 hover:border-accent hover:bg-card-hover">
  <!-- Icon Wrapper 40px -->
  <div class="w-10 h-10 mb-6 text-accent transition-all group-hover:scale-110">
    {icon === 'code' && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>}
    
    {icon === 'wordpress' && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"></path><path d="M16 12l-2-6-2 6-2-6-2 6s0 0 0 0h2.5l2 4 2-4h2.5s0 0 0 0z"></path></svg>}
    
    {icon === 'rocket' && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.71-2.13.09-2.91a2.18 2.18 0 0 0-3.09-.09z"></path><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-4 5-4"></path><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 4-5 4-5"></path></svg>}
    
    {icon === 'wrench' && <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>}
  </div>

  <h3 class="text-[20px] font-bold font-body mb-4 group-hover:text-accent transition-colors">
    {title}
  </h3>
  
  <p class="text-text-secondary text-[15px] line-height-[1.7] font-body leading-relaxed">
    {description}
  </p>
</div>
