---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const pageTitle = "404 - Página no encontrada";
---

<BaseLayout pageTitle={pageTitle} description="La página que buscás no existe o fue movida.">
  <section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-6">
    <span class="font-display text-[150px] md:text-[200px] leading-none text-accent/20 animate-pulse">404</span>
    <h1 class="text-4xl md:text-6xl mb-6">Página no encontrada</h1>
    <p class="text-text-secondary text-lg max-w-[500px] mb-12 font-body">
      Parece que te perdiste en el código. La página que buscás no existe o se tomó un descanso.
    </p>
    <Button text="Volver al inicio" href="/" variant="primary" />
  </section>
</BaseLayout>
